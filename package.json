{
  "author": {
    "email": "km.8k6ce+npm@gmail.com",
    "name": "kei-g"
  },
  "bin": {
    "emojify": "bin/emojify.js"
  },
  "bugs": {
    "url": "https://github.com/kei-g/emojify-js/issues"
  },
  "description": "Text formatter for `:emoji:` style",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "c8": "^12.0.0",
    "esbuild": "^0.28.1",
    "esbuild-register": "^3.6.0",
    "mkdirp": "^3.0.1",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=4.0.0"
  },
  "homepage": "https://github.com/kei-g/emojify-js",
  "keywords": [
    "convert",
    "converter",
    "emoji",
    "emojify",
    "emojifier",
    "emojis",
    "emoticon",
    "format",
    "formatter",
    "ideogram",
    "ideograms",
    "text",
    "text-convert",
    "text-converter",
    "text-format",
    "text-formatter",
    "utility",
    "utilities"
  ],
  "license": "BSD-3-Clause",
  "main": "index.js",
  "name": "@kei-g/emojify",
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "github:kei-g/emojify-js",
  "scripts": {
    "build": "npm-run-all2 --parallel build:bundle build:emojify build:tsc",
    "build:assets": "npm-run-all2 --sequential build:assets:mkdir build:assets:copy",
    "build:assets:copy": "ln node-emoji/lib/emoji.json assets/",
    "build:assets:mkdir": "mkdirp assets",
    "build:bundle": "esbuild src/index.ts --bundle --charset=utf8 --format=esm --minify --outfile=index.js --platform=node --target=esnext",
    "build:emojify": "esbuild src/bin/emojify.ts --charset=utf8 --format=esm --minify --outfile=bin/emojify.js --platform=node --target=esnext",
    "build:tsc": "tsc",
    "clean": "npm-run-all2 --sequential clean:assets:rm build:assets:mkdir clean:assets:link",
    "clean:assets:link": "ln -s ../node-emoji/lib/emoji.json assets/",
    "clean:assets:rm": "rimraf assets/",
    "clean:dist": "rimraf bin/ build/ coverage/ index.d.ts index.js lib/",
    "cover": "c8 node --test",
    "distclean": "npm-run-all2 --parallel clean clean:dist",
    "lint": "biome lint --write",
    "postbuild": "rimraf bin/emojify.d.ts",
    "postpublish": "npm run distclean",
    "prebuild": "npm-run-all2 --parallel distclean lint",
    "prepublishOnly": "run-s build clean:assets:rm build:assets",
    "start": "node --require esbuild-register src/bin/emojify.ts",
    "test": "npm-run-all2 --parallel cover lint"
  },
  "type": "module",
  "types": "index.d.ts",
  "version": "1.1.18"
}
