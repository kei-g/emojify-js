{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationDir": ".",
    "downlevelIteration": true,
    "emitDeclarationOnly": true,
    "ignoreDeprecations": "6.0",
    "lib": [
      "ES2015",
    ],
    "module": "NodeNext",
    "moduleResolution": "Nodenext",
    "newLine": "lf",
    "pretty": true,
    "removeComments": true,
    "rootDir": ".",
    "strict": true,
    "strictNullChecks": false,
    "target": "esnext",
    "types": [
      "node",
    ],
  },
  "exclude": [],
  "include": [
    "src",
  ],
}
